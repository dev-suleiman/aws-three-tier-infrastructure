region      = "eu-north-1"
environment = "dev"
vpc_cidr    = "10.0.0.0/16"

# EC2
instance_type   = "t2.micro"
public_key_path = "~/.ssh/my-ec2-key.pub"

# Web Tier Scaling
web_min_size         = 1
web_max_size         = 4
web_desired_capacity = 2

# App Tier Scaling
app_min_size         = 1
app_max_size         = 4
app_desired_capacity = 2

# Database
db_name           = "appdb"
db_username       = "dbadmin"
db_password       = "ChangeMe123!"
db_instance_class = "db.t3.micro"
multi_az          = false

# ElastiCache
redis_node_type          = "cache.t3.micro"
redis_num_cache_clusters = 1

# S3
bucket_name = "your-name-three-tier-app-bucket-2024"